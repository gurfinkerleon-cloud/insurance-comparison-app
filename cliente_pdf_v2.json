        "initialMessages": "שלום! אני אסיסטנט הביטוח שלך.\nשלח/י את מספר הטלפון שלך ואבדוק אם כבר נרשמת. אם לקוח/ה חדש/ה - צרף/י גם את קובץ הפוליסה PDF.",
        "options": { "allowFileUploads": true }
      },
      "type": "@n8n/n8n-nodes-langchain.chatTrigger",
      "typeVersion": 1.4,
      "position": [-600, 0],
      "id": "node-001",
      "name": "When chat message received",
      "webhookId": "912a281e-68bb-4695-9d00-a27abec4c1cb"
    },
    {
      "parameters": {
        "jsCode": "const chatInput = $json.chatInput || '';\nconst sessionId = $json.sessionId || '';\n\nconst israeliPhone = /05\\d{8}/;\nconst normalize = s => (s || '').replace(/[-\\s]/g, '');\nconst fromChat = normalize(chatInput).match(israeliPhone);\nconst phone = fromChat ? fromChat[0] : null;\n\n// Persist phone number across conversation turns\nconst staticData = $getWorkflowStaticData('global');\nif (phone && sessionId) {\n  staticData[sessionId] = phone;\n}\nconst savedPhone = sessionId ? (staticData[sessionId] || null) : null;\nconst resolvedPhone = phone || savedPhone;\nconst phoneIsValid = resolvedPhone !== null && /^05\\d{8}$/.test(resolvedPhone);\n\nconst hasPdf = Object.keys($binary || {}).length > 0;\nconst binaryKey = hasPdf ? Object.keys($binary)[0] : null;\n\nreturn [{\n  json: {\n    ...$json,\n    phone_number: resolvedPhone || sessionId,\n    phone_is_valid: phoneIsValid,\n    has_pdf: hasPdf,\n    binary_key: binaryKey\n  },\n  binary: $binary || {}\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-420, 0],
      "id": "node-002a",
      "name": "Extract Phone"
