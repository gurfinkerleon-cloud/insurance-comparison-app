    {
      "parameters": {
        "jsCode": "const body = $json.body || $json;\n\nconst typeWebhook = body.typeWebhook || '';\nif (typeWebhook !== 'incomingMessageReceived') {\n  return [];\n}\n\nconst chatId = body.senderData?.chatId || '';\nconst senderName = body.senderData?.senderName || '';\nconst typeMessage = body.messageData?.typeMessage || '';\n\nlet chatInput = '';\nif (typeMessage === 'textMessage') {\n  chatInput = body.messageData?.textMessageData?.textMessage || '';\n} else if (typeMessage === 'extendedTextMessage') {\n  chatInput = body.messageData?.extendedTextMessageData?.text || '';\n}\n\nconst wid = chatId.replace('@c.us', '');\nlet phone = wid.startsWith('972') ? '0' + wid.slice(3) : wid;\n\nconst hasFile = ['documentMessage', 'imageMessage'].includes(typeMessage);\nconst fileUrl = hasFile ? (body.messageData?.fileMessageData?.downloadUrl || '') : '';\nconst fileName = hasFile ? (body.messageData?.fileMessageData?.fileName || 'file.pdf') : '';\n\nreturn [{\n  json: {\n    chatId,\n    chatInput,\n    phone_number: phone,\n    phone_is_valid: /^05\\d{8}$/.test(phone),\n    has_pdf: hasFile && fileUrl !== '',\n    file_url: fileUrl,\n    file_name: fileName,\n    sender_name: senderName\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-420, 0],
      "id": "node-002a",
      "name": "Parse WhatsApp Input"
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": false, "leftValue": "", "typeValidation": "loose", "version": 2 },
